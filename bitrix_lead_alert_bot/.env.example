# Telegram BotFather token
TELEGRAM_BOT_TOKEN=8919044246:AAFh954KWtWkph3DXiQLKIYnfyeLGc3dYms

# Telegram group/supergroup chat ID. Example: -1001234567890
TELEGRAM_CHAT_ID=-1003963026499

# Telegram user ID of the responsible person to mention
TELEGRAM_MENTION_USER_ID=848809437
TELEGRAM_MENTION_NAME=Mukhtarov A'lo

# Bitrix24 incoming webhook base URL.
# Example: https://yourcompany.bitrix24.ru/rest/1/xxxxxxxxxxxxxxxx/
BITRIX_WEBHOOK_BASE_URL=https://allmax.bitrix24.kz/rest/1/7pcjyettqel2ef66/

# Public Bitrix24 portal URL for clickable lead links.
# Example: https://yourcompany.bitrix24.ru
BITRIX_PORTAL_URL=https://allmax.bitrix24.kz

# Optional shared secret for incoming /bitrix/lead endpoint.
# Put this value in Bitrix outgoing webhook URL as ?secret=CHANGE_ME_LONG_RANDOM
WEBHOOK_SECRET=rIMbLq9_i_fkYAl0qo7R73tLuUy5aGzL1_b_sctC9ZY

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
TIMEZONE=Asia/Tashkent
LOG_LEVEL=INFO

# Database and logs
DATABASE_PATH=./data/bot.db
LOG_FILE=./logs/bot.log

# Reliability settings
POLL_INTERVAL_SECONDS=60
POLL_LOOKBACK_LIMIT=50
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY_SECONDS=2
REQUEST_TIMEOUT_SECONDS=20

# Realtime-only protection
# true = bot only notifies about leads created after the bot baseline/start.
REALTIME_ONLY_MODE=true

# false = first launch will NOT send old existing Bitrix leads.
# Keep false if you need only real-time new leads.
POLL_SEND_UNKNOWN_ON_START=false

# Small delay between Telegram messages to avoid 429 Too Many Requests.
TELEGRAM_MIN_DELAY_SECONDS=1.2
