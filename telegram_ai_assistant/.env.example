# ==========================================
# Telegram User API (my.telegram.org dan oling)
# Bu sizning SHAXSIY akkountingiz - guruhlar, kanallar, xabarlar tarixini
# o'qish va yozish uchun ishlatiladi.
# ==========================================
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+998901234567
TELEGRAM_SESSION_NAME=user_session

# ==========================================
# Buyruq qabul qiluvchi bot (@BotFather dan oling: /newbot)
# Siz shu botga TZ (topshiriq) yozasiz
# ==========================================
COMMAND_BOT_TOKEN=

# Faqat shu Telegram user ID'dan kelgan xabarlarga javob beradi.
# O'z ID'ingizni bilish uchun @userinfobot ga yozing.
OWNER_USER_ID=

# ==========================================
# Anthropic Claude API (console.anthropic.com)
# ==========================================
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Agent bir vazifa uchun ketma-ket nechta tool-chaqiruv qila olishi (loop limit)
MAX_AGENT_STEPS=25

LOG_LEVEL=INFO
